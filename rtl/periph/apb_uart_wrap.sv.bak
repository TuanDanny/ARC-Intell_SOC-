/*
 * Module: apb_uart_wrap
 * Description: Bộ điều khiển UART (Universal Asynchronous Receiver/Transmitter)
 *              được tích hợp giao diện APB Slave tiêu chuẩn.
 *              Thay thế cấu trúc phức tạp OBI bằng kiến trúc phẳng (Flat Architecture) dễ tích hợp.
 *
 * Registers Map:
 * - 0x00 (RW): DATA REGISTER (TX/RX Buffer)
 * - 0x04 (RW): STATUS REGISTER
 *              [0] TX Busy
 *              [1] RX Valid (Data Ready)
 * - 0x08 (RW): BAUD DIVIDER (Frequency / Baudrate)
 */

module apb_uart_wrap #(
    parameter APB_ADDR_WIDTH = 32,
    parameter APB_DATA_WIDTH = 32
) (
    // 1. Giao diện Clock & Reset
    input  logic                      clk_i,
    input  logic                      rst_ni,

    // 2. Giao diện APB Slave
    input  logic [APB_ADDR_WIDTH-1:0] paddr_i,   // Địa chỉ
    input  logic [APB_DATA_WIDTH-1:0] pwdata_i,  // Dữ liệu ghi
    input  logic                      pwrite_i,  // Lệnh Ghi (1) / Đọc (0)
    input  logic                      psel_i,    // Tín hiệu chọn thiết bị
    input  logic                      penable_i, // Tín hiệu cho phép (Enable Phase)
    output logic [APB_DATA_WIDTH-1:0] prdata_o,  // Dữ liệu đọc về
    output logic                      pready_o,  // Thiết bị sẵn sàng
    output logic                      pslverr_o, // Báo lỗi

    // 3. Giao diện Vật lý (RS232 Physical)
    output logic                      sout_o,    // TX (Transmit)
    input  logic                      sin_i,     // RX (Receive)
    
    // 4. Các tín hiệu modem (Treo sẵn logic để tương thích code cũ)
    output logic                      intr_o,    // Ngắt (Interrupt)
    input  logic                      cts_ni     // Clear To Send
);

    // =========================================================================
    // 1. KHAI BÁO TÀI NGUYÊN (RESOURCES)
    // =========================================================================
    // Tín hiệu giao tiếp APB
    logic write_en, read_en;
    logic [7:0] addr_offset;

    // Thanh ghi nội bộ
    logic [15:0] reg_baud_div;  // Thanh ghi chia tần số Baud
    logic [7:0]  reg_tx_data;   // Bộ đệm phát
    logic [7:0]  reg_rx_data;   // Bộ đệm thu
    logic        rx_data_valid; // Cờ báo có dữ liệu
    
    // Tín hiệu trạng thái UART
    logic tx_busy, tx_start;
    logic rx_busy, rx_done;
    
    // Giá trị Baud mặc định (50MHz / 115200 ≈ 434)
    localparam DEFAULT_DIV = 16'd434; 

    // Gán tĩnh các tín hiệu chưa dùng (Clean Code)
    assign intr_o    = rx_data_valid; // Kích hoạt ngắt khi có dữ liệu đến
    assign pslverr_o = 1'b0;          // Không hỗ trợ báo lỗi Bus
    assign pready_o  = 1'b1;          // Luôn sẵn sàng (Single Cycle Access)

    // Giải mã Bus APB
    assign addr_offset = paddr_i[7:0]; // Chỉ quan tâm 8 bit cuối
    assign write_en    = psel_i & penable_i & pwrite_i;
    assign read_en     = psel_i & !pwrite_i; // (Data valid at Setup Phase in Read)

    // =========================================================================
    // 2. KHỐI THANH GHI (REGISTER FILE) & GIAO TIẾP BUS
    // =========================================================================
    
    always_ff @(posedge clk_i or negedge rst_ni) begin
        if (!rst_ni) begin
            reg_baud_div  <= DEFAULT_DIV;
            tx_start      <= 1'b0;
            reg_tx_data   <= 8'd0;
            prdata_o      <= 32'd0;
            rx_data_valid <= 1'b0;
        end else begin
            // Mặc định xóa tín hiệu điều khiển (Autoreset)
            tx_start <= 1'b0;

            // --- WRITE LOGIC ---
            if (write_en) begin
                case (addr_offset)
                    8'h00: begin // Ghi vào DATA -> Kích hoạt gửi
                        reg_tx_data <= pwdata_i[7:0];
                        tx_start    <= 1'b1; // Pulse kích hoạt
                    end
                    8'h08: begin // Cấu hình Baudrate
                        reg_baud_div <= pwdata_i[15:0];
                    end
                    // 0x04 là Status Register (Read-only)
                    default: ;
                endcase
            end

            // --- READ LOGIC ---
            // Nếu Bus đang đọc (PSEL=1, WRITE=0), trả về dữ liệu
            if (psel_i && !pwrite_i) begin
                case (addr_offset)
                    8'h00: prdata_o <= {24'd0, reg_rx_data};  // Đọc dữ liệu RX
                    8'h04: prdata_o <= {30'd0, rx_data_valid, tx_busy}; // Status
                    8'h08: prdata_o <= {16'd0, reg_baud_div}; // Đọc Baudrate
                    default: prdata_o <= 32'd0;
                endcase
                
                // Cơ chế tự xóa cờ (Clear-on-Read): Đọc data xong thì xóa cờ Valid
                if (addr_offset == 8'h00) rx_data_valid <= 1'b0; 
            end

            // Cập nhật trạng thái RX từ phần cứng
            if (rx_done) rx_data_valid <= 1'b1;
        end
    end

    // =========================================================================
    // 3. LOGIC TRUYỀN DỮ LIỆU (TX CORE - STATE MACHINE)
    // =========================================================================
    logic [15:0] tx_clk_cnt;
    logic [3:0]  tx_bit_idx;
    
    // States
    enum logic [1:0] {TX_IDLE, TX_START, TX_DATA, TX_STOP} tx_state;

    always_ff @(posedge clk_i or negedge rst_ni) begin
        if (!rst_ni) begin
            tx_state   <= TX_IDLE;
            tx_busy    <= 1'b0;
            sout_o     <= 1'b1; // Idle line is High
            tx_clk_cnt <= 16'd0;
            tx_bit_idx <= 4'd0;
        end else begin
            case (tx_state)
                TX_IDLE: begin
                    sout_o <= 1'b1;
                    if (tx_start) begin
                        tx_state   <= TX_START;
                        tx_busy    <= 1'b1;
                        tx_clk_cnt <= 16'd0;
                    end else begin
                        tx_busy <= 1'b0;
                    end
                end

                TX_START: begin
                    sout_o <= 1'b0; // Start bit = 0
                    if (tx_clk_cnt < reg_baud_div) 
                        tx_clk_cnt <= tx_clk_cnt + 1;
                    else begin
                        tx_clk_cnt <= 16'd0;
                        tx_state   <= TX_DATA;
                        tx_bit_idx <= 4'd0;
                    end
                end

                TX_DATA: begin
                    sout_o <= reg_tx_data[tx_bit_idx]; // Shift out data LSB first
                    if (tx_clk_cnt < reg_baud_div)
                        tx_clk_cnt <= tx_clk_cnt + 1;
                    else begin
                        tx_clk_cnt <= 16'd0;
                        if (tx_bit_idx < 7)
                            tx_bit_idx <= tx_bit_idx + 1;
                        else
                            tx_state   <= TX_STOP;
                    end
                end

                TX_STOP: begin
                    sout_o <= 1'b1; // Stop bit = 1
                    if (tx_clk_cnt < reg_baud_div)
                        tx_clk_cnt <= tx_clk_cnt + 1;
                    else begin
                        tx_state   <= TX_IDLE; // Done
                        tx_busy    <= 1'b0;
                    end
                end
            endcase
        end
    end

    // =========================================================================
    // 4. LOGIC NHẬN DỮ LIỆU (RX CORE) - ĐƠN GIẢN HÓA
    // =========================================================================
    // Để giữ code sạch và đủ dùng, RX Core chỉ thực hiện Oversampling cơ bản
    logic [15:0] rx_clk_cnt;
    logic [3:0]  rx_bit_idx;
    enum logic [1:0] {RX_IDLE, RX_WAIT_CENTER, RX_RECV, RX_STOP} rx_state;
    
    // Synchronizer (Chống nhiễu Metastability cho chân sin_i)
    logic rx_sync_1, rx_sync_2;
    always_ff @(posedge clk_i) begin
        rx_sync_1 <= sin_i;
        rx_sync_2 <= rx_sync_1;
    end

    always_ff @(posedge clk_i or negedge rst_ni) begin
        if (!rst_ni) begin
            rx_state    <= RX_IDLE;
            rx_done     <= 1'b0;
            reg_rx_data <= 8'd0;
            rx_busy     <= 1'b0;
        end else begin
            rx_done <= 1'b0; // Pulse chỉ bật 1 chu kỳ

            case (rx_state)
                RX_IDLE: begin
                    rx_busy <= 1'b0;
                    if (rx_sync_2 == 1'b0) begin // Detect Start Bit (High -> Low)
                        rx_state   <= RX_WAIT_CENTER;
                        rx_clk_cnt <= 16'd0;
                        rx_busy    <= 1'b1;
                    end
                end

                RX_WAIT_CENTER: begin
                    // Đợi đến giữa bit (Half Baud Cycle)
                    if (rx_clk_cnt < {1'b0, reg_baud_div[15:1]}) 
                        rx_clk_cnt <= rx_clk_cnt + 1;
                    else begin
                        rx_clk_cnt <= 16'd0;
                        rx_state   <= RX_RECV;
                        rx_bit_idx <= 4'd0;
                    end
                end

                RX_RECV: begin
                    if (rx_clk_cnt < reg_baud_div)
                        rx_clk_cnt <= rx_clk_cnt + 1;
                    else begin
                        rx_clk_cnt <= 16'd0;
                        reg_rx_data[rx_bit_idx] <= rx_sync_2; // Sample bit
                        
                        if (rx_bit_idx < 7)
                            rx_bit_idx <= rx_bit_idx + 1;
                        else
                            rx_state <= RX_STOP;
                    end
                end

                RX_STOP: begin
                    if (rx_clk_cnt < reg_baud_div)
                        rx_clk_cnt <= rx_clk_cnt + 1;
                    else begin
                        rx_state <= RX_IDLE;
                        rx_done  <= 1'b1; // Hoàn thành 1 byte
                    end
                end
            endcase
        end
    end

endmodule