/*
 * Module: top_soc
 * Description: MODULE TỔNG HỢP HOÀN CHỈNH 100%
 *              Kết nối CPU (8-bit) -> Interconnect -> [RAM, DSP, GPIO, UART, TIMER]
 * Status: GOLDEN MASTER (Ready for FPGA Implementation)
 */

`include "apb_bus.sv"  // Định nghĩa Interface Bus
`include "config.sv"   // Định nghĩa Bản đồ bộ nhớ (đã sửa ở Bước 1)

module top_soc (
    input  logic       clk_i,          // 50 MHz Clock
    input  logic       rst_ni_async,   // Reset nút nhấn (Active Low)

    // --- 1. GIAO DIỆN ADC (SPI Master) ---
    input  logic       adc_miso_i,     // Dữ liệu từ ADC về
    output logic       adc_sclk_o,     // Xung nhịp cho ADC
    output logic       adc_csn_o,      // Chọn chip ADC

    // --- 2. GIAO DIỆN UART (PC Communication) ---
    output logic       uart_tx_o,      
    input  logic       uart_rx_i,

    // --- 3. GIAO DIỆN ĐIỀU KHIỂN & BÁO HIỆU ---
    // [0]: Relay (Cắt điện), [3:1]: Đèn LED báo lỗi
    inout  wire [31:0] gpio_pin_io     
);

    // ========================================================================
    // 1. KHỐI RESET & ĐỒNG BỘ HÓA
    // ========================================================================
    logic rst_no; // Reset toàn cục (Synchronized)
    
    // Module tạo Reset sạch, tránh Metastability
    rstgen u_rstgen (
        .clk_i       (clk_i),
        .rst_ni      (rst_ni_async),
        .test_mode_i (1'b0),
        .rst_no      (rst_no),
        .init_no     ()
    );

    // ========================================================================
    // 2. KHAI BÁO BUS LIÊN KẾT (INTERCONNECT WIRE HARNESS)
    // ========================================================================
    // Định nghĩa số lượng thiết bị ngoại vi (Slave)
    // 0: RAM | 1: DSP | 2: GPIO | 3: UART | 4: TIMER
    localparam NB_SLAVE = 5;

    // Các bó dây kết nối từ Bộ phân chia (Node) đến từng Slave
    logic [NB_SLAVE-1:0]        s_penable;
    logic [NB_SLAVE-1:0]        s_pwrite;
    logic [NB_SLAVE-1:0]        s_psel;
    logic [NB_SLAVE-1:0][31:0]  s_paddr;
    logic [NB_SLAVE-1:0][31:0]  s_pwdata;
    logic [NB_SLAVE-1:0][31:0]  s_prdata;
    logic [NB_SLAVE-1:0]        s_pready;
    logic [NB_SLAVE-1:0]        s_pslverr;

    // Interface kết nối từ CPU Master đến Node phân chia
    APB_BUS apb_cpu_master(); 

    // Bản đồ địa chỉ (Phải khớp với config.sv và Logic CPU)
    logic [NB_SLAVE-1:0][31:0] start_addr;
    logic [NB_SLAVE-1:0][31:0] end_addr;

    assign start_addr[0] = `RAM_BASE_ADDR;   assign end_addr[0] = `RAM_BASE_ADDR   + 32'h0FFF;
    assign start_addr[1] = `DSP_BASE_ADDR;   assign end_addr[1] = `DSP_BASE_ADDR   + 32'h0FFF;
    assign start_addr[2] = `GPIO_BASE_ADDR;  assign end_addr[2] = `GPIO_BASE_ADDR  + 32'h0FFF;
    assign start_addr[3] = `UART_BASE_ADDR;  assign end_addr[3] = `UART_BASE_ADDR  + 32'h0FFF;
    assign start_addr[4] = `TIMER_BASE_ADDR; assign end_addr[4] = `TIMER_BASE_ADDR + 32'h0FFF;

    // Module "Cảnh sát giao thông" điều phối dữ liệu
    apb_node #(
        .NB_MASTER      (NB_SLAVE), // Config thư viện này hơi ngược, Master Port ở đây nghĩa là cổng ra Slave
        .APB_ADDR_WIDTH (32),
        .APB_DATA_WIDTH (32)
    ) u_interconnect (
        // Input từ CPU
        .paddr_i    (apb_cpu_master.paddr),
        .pwdata_i   (apb_cpu_master.pwdata),
        .pwrite_i   (apb_cpu_master.pwrite),
        .psel_i     (apb_cpu_master.psel),
        .penable_i  (apb_cpu_master.penable),
        .prdata_o   (apb_cpu_master.prdata),
        .pready_o   (apb_cpu_master.pready),
        .pslverr_o  (apb_cpu_master.pslverr),

        // Output ra các thiết bị con
        .paddr_o    (s_paddr),
        .pwdata_o   (s_pwdata),
        .pwrite_o   (s_pwrite),
        .psel_o     (s_psel),
        .penable_o  (s_penable),
        .prdata_i   (s_prdata),
        .pready_i   (s_pready),
        .pslverr_i  (s_pslverr),

        // Config vùng nhớ
        .START_ADDR_i (start_addr),
        .END_ADDR_i   (end_addr)
    );

    // ========================================================================
    // 3. MASTER CPU
    // ========================================================================
    logic irq_arc_critical; // Tín hiệu báo cháy từ DSP
    logic irq_timer_tick;   // Tín hiệu ngắt thời gian

    cpu_8bit #(
        .ROM_SIZE (256),
        .RAM_SIZE (128)
    ) u_cpu (
        .clk_i       (clk_i),
        .rst_ni      (rst_no),
        .irq_arc_i   (irq_arc_critical),
        .irq_timer_i (irq_timer_tick),
        .apb_mst     (apb_cpu_master)
    );

    // ========================================================================
    // 4. CÁC KHỐI NGOẠI VI (PERIPHERALS)
    // ========================================================================

    // --------------------------------------------------------
    // SLAVE 0: INTERNAL RAM (Lưu trữ biến tạm)
    // --------------------------------------------------------
    logic [31:0] ram_mem [0:255];
    
    always_ff @(posedge clk_i) begin
        if (s_psel[0] && s_penable[0] && s_pwrite[0])
            ram_mem[s_paddr[0][9:2]] <= s_pwdata[0];
    end
    
    assign s_prdata[0]  = ram_mem[s_paddr[0][9:2]];
    assign s_pready[0]  = 1'b1; // RAM đáp ứng ngay lập tức
    assign s_pslverr[0] = 1'b0;

    // --------------------------------------------------------
    // SLAVE 1: DSP (BỘ PHÁT HIỆN HỒ QUANG)
    // --------------------------------------------------------
    // Lưu ý: DSP dùng Interface SV, ta cần adapter chuyển Wire -> Interface
    APB_BUS apb_dsp_if();
    
    assign apb_dsp_if.paddr   = s_paddr[1];
    assign apb_dsp_if.pwdata  = s_pwdata[1];
    assign apb_dsp_if.pwrite  = s_pwrite[1];
    assign apb_dsp_if.psel    = s_psel[1];
    assign apb_dsp_if.penable = s_penable[1];
    
    // Map ngược lại
    assign s_prdata[1]  = apb_dsp_if.prdata;
    assign s_pready[1]  = apb_dsp_if.pready;
    assign s_pslverr[1] = apb_dsp_if.pslverr;

    // Logic thu thập dữ liệu SPI (ADC Driver)
    // 16-bit Data, SPI Mode 0, ~250kSPS tùy vào bộ chia
    logic [15:0] spi_data_val;
    logic        spi_data_rdy;
    logic [5:0]  spi_bit_cnt;
    logic [15:0] spi_shift_reg;

    always_ff @(posedge clk_i or negedge rst_no) begin
        if (!rst_no) begin
            spi_bit_cnt <= 0;
            adc_csn_o   <= 1'b1;
            spi_data_rdy <= 0;
        end else begin
            // Máy trạng thái SPI đơn giản (Counter based)
            // Chu kỳ lấy mẫu ví dụ
            spi_bit_cnt <= spi_bit_cnt + 1; 
            
            // Bit 1 của Counter làm Clock (Freq = Clk/4)
            adc_sclk_o  <= spi_bit_cnt[1]; 

            // Chip Select kéo xuống thấp để bắt đầu khung
            if (spi_bit_cnt == 6'd0) adc_csn_o <= 1'b0;
            
            // Shift data vào tại sườn dương clock ảo
            if (spi_bit_cnt[1] == 1 && spi_bit_cnt[0] == 0)
                spi_shift_reg <= {spi_shift_reg[14:0], adc_miso_i};

            // Kết thúc khung 16-bit
            if (spi_bit_cnt == 6'd63) begin
                adc_csn_o <= 1'b1;
                spi_data_val <= spi_shift_reg; // Đẩy dữ liệu sang DSP
                spi_data_rdy <= 1'b1;
            end else begin
                spi_data_rdy <= 1'b0;
            end
        end
    end

    dsp_arc_detect #(
        .DATA_WIDTH(16), .CNT_WIDTH(16)
    ) u_dsp_core (
        .clk_i       (clk_i),
        .rst_ni      (rst_no),
        .adc_data_i  (spi_data_val), // Dữ liệu từ Logic SPI trên
        .adc_valid_i (spi_data_rdy),
        .apb_slv     (apb_dsp_if),   // Interface điều khiển
        .irq_arc_o   (irq_arc_critical)
    );

    // --------------------------------------------------------
    // SLAVE 2: GPIO (ĐIỀU KHIỂN RELAY)
    // --------------------------------------------------------
    logic [31:0] gpio_out_wire, gpio_dir_wire;
    
    apb_gpio #(
        .APB_ADDR_WIDTH(12), 
        .PAD_NUM(32)
    ) u_gpio (
        .HCLK      (clk_i),
        .HRESETn   (rst_no),
        // Kết nối BUS APB Slave 2
        .PADDR     (s_paddr[2][11:0]), 
        .PWDATA    (s_pwdata[2]),
        .PWRITE    (s_pwrite[2]),
        .PSEL      (s_psel[2]),
        .PENABLE   (s_penable[2]),
        .PRDATA    (s_prdata[2]),
        .PREADY    (s_pready[2]),
        .PSLVERR   (s_pslverr[2]),
        
        .gpio_in   (32'd0),
        .gpio_out  (gpio_out_wire),
        .gpio_dir  (gpio_dir_wire),
        .interrupt ()
    );

    // SAFETY INTERLOCK: Relay chỉ được đóng khi hệ thống Reset xong và có lệnh.
    // Nếu Reset tích cực (0), ép Relay về 0.
    // Bit 0: Relay | Bit 1,2,3: LED
    assign gpio_pin_io[0]   = (!rst_no) ? 1'b0 : (gpio_dir_wire[0] ? gpio_out_wire[0] : 1'bz);
    assign gpio_pin_io[3:1] = gpio_dir_wire[3:1] ? gpio_out_wire[3:1] : 3'bz; 

    // --------------------------------------------------------
    // SLAVE 3: UART (DÙNG MODULE PHẲNG MỚI VIẾT)
    // --------------------------------------------------------
    apb_uart_wrap u_uart (
        .clk_i     (clk_i),
        .rst_ni    (rst_no),
        // Kết nối BUS APB Slave 3
        .paddr_i   (s_paddr[3]),
        .pwdata_i  (s_pwdata[3]),
        .pwrite_i  (s_pwrite[3]),
        .psel_i    (s_psel[3]),
        .penable_i (s_penable[3]),
        .prdata_o  (s_prdata[3]),
        .pready_o  (s_pready[3]),
        .pslverr_o (s_pslverr[3]),
        // IO
        .sout_o    (uart_tx_o),
        .sin_i     (uart_rx_i),
        .intr_o    (),       // Không dùng ngắt UART để đơn giản
        .cts_ni    (1'b0)    // Always Clear-To-Send
    );

    // --------------------------------------------------------
    // SLAVE 4: ADVANCED TIMER
    // --------------------------------------------------------
    apb_adv_timer #(
        .APB_ADDR_WIDTH(12)
    ) u_timer (
        .HCLK      (clk_i),
        .HRESETn   (rst_no),
        // Kết nối BUS APB Slave 4
        .PADDR     (s_paddr[4][11:0]),
        .PWDATA    (s_pwdata[4]),
        .PWRITE    (s_pwrite[4]),
        .PSEL      (s_psel[4]),
        .PENABLE   (s_penable[4]),
        .PRDATA    (s_prdata[4]),
        .PREADY    (s_pready[4]),
        .PSLVERR   (s_pslverr[4]),
        // Config inputs
        .low_speed_clk_i (1'b0), 
        .dft_cg_enable_i (1'b0),
        .ext_sig_i       (32'd0),
        .events_o        ({irq_timer_tick, 3'b000}) // Kênh 3 tạo ngắt
    );

endmodule